# WealthFlow — environment variables
# Copy to .env.local and fill in your values.

# ── AI (FREE) ────────────────────────────────────────────────────────────────
# Groq — llama-3.3-70b-versatile (free, fast, generous limits)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# ── WEB SEARCH / GROUNDING (FREE tier) ───────────────────────────────────────
# Tavily — gives the AI REAL web data (real prospects, real research) instead of
# inventing from memory. Used by the AI Lead Generator + Prospect Research.
# Get a free key (generous free tier) at: https://app.tavily.com
TAVILY_API_KEY=tvly-your_tavily_key_here

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Supabase — create a free project at: https://supabase.com
# Run supabase/migrations/0001_init.sql in the SQL editor, then copy these from
# Project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
